NODE_ENV=development

# Docker compose
POSTGRES_DB=taurus
POSTGRES_USER=taurus
POSTGRES_PASSWORD=taurus
POSTGRES_PORT=5433
MONGO_INITDB_DATABASE=taurus_access
MONGO_PORT=27018
NGINX_PORT=8080

# Shared infrastructure
REDIS_HOST=redis
REDIS_PORT=6379
MQTT_URL=mqtt://mosquitto:1883

# auth-service
AUTH_SERVICE_PORT=3000
AUTH_DB_HOST=postgres
AUTH_DB_PORT=5432
AUTH_DB_NAME=taurus
AUTH_DB_USER=taurus
AUTH_DB_PASSWORD=taurus
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# members-service
MEMBERS_SERVICE_PORT=3001
MEMBERS_DB_HOST=postgres
MEMBERS_DB_PORT=5432
MEMBERS_DB_NAME=taurus
MEMBERS_DB_USER=taurus
MEMBERS_DB_PASSWORD=taurus

# access-service
ACCESS_SERVICE_PORT=3002
ACCESS_MONGO_URI=mongodb://mongo:27017/taurus_access
MEMBERS_SERVICE_BASE_URL=http://members-service:3001
