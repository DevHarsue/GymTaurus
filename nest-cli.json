{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "apps/auth-service/src",
    "compilerOptions": {
        "deleteOutDir": true
    },
    "monorepo": true,
    "root": "apps/auth-service",
    "projects": {
        "access-service": {
            "type": "application",
            "root": "apps/access-service",
            "entryFile": "main",
            "sourceRoot": "apps/access-service/src",
            "compilerOptions": {
                "tsConfigPath": "apps/access-service/tsconfig.app.json"
            }
        },
        "auth-service": {
            "type": "application",
            "root": "apps/auth-service",
            "entryFile": "main",
            "sourceRoot": "apps/auth-service/src",
            "compilerOptions": {
                "tsConfigPath": "apps/auth-service/tsconfig.app.json"
            }
        },
        "common": {
            "type": "library",
            "root": "libs/common",
            "entryFile": "index",
            "sourceRoot": "libs/common/src",
            "compilerOptions": {
                "tsConfigPath": "libs/common/tsconfig.lib.json"
            }
        },
        "members-service": {
            "type": "application",
            "root": "apps/members-service",
            "entryFile": "main",
            "sourceRoot": "apps/members-service/src",
            "compilerOptions": {
                "tsConfigPath": "apps/members-service/tsconfig.app.json",
                "plugins": ["@nestjs/swagger"]
            }
        }
    }
}
